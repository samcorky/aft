# Database Configuration
MYSQL_ROOT_PASSWORD=your_root_password_here
MYSQL_DATABASE=aft_db
MYSQL_USER=aft_user
MYSQL_PASSWORD=your_user_password_here

# Application Configuration
FLASK_ENV=development
FLASK_DEBUG=1

# Flask Secret Key (REQUIRED)
# Used to cryptographically sign session cookies. Must be a strong random value.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# WARNING: If this is not set, the server will refuse to start.
# Never reuse this value across environments. Rotate immediately if compromised.
SECRET_KEY=replace-with-a-generated-random-secret

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# Session Storage Configuration
# Set to true to store sessions server-side in Redis (recommended).
# Set to false to use Flask's signed client-side session cookies.
# If true, REDIS_URL must be set.
ENABLE_SERVER_SIDE_SESSIONS=true

# Session Cookie Transport Security
# Default true: browser only sends session cookies over HTTPS.
# Set to false only for controlled local HTTP-only testing.
SESSION_COOKIE_SECURE=true

# Health Check Security Configuration
# Token used by internal readiness health checks.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
HEALTHCHECK_TOKEN=replace-with-a-generated-random-healthcheck-token
# Source IP allowed to call internal readiness endpoint.
# Default is same-host compose; override for split-host deployments.
HEALTHCHECK_ALLOWED_SOURCE_IP=127.0.0.1

# CORS Configuration
# Comma-separated list of origins allowed to connect via HTTP, HTTPS, and WebSocket
# For development: include both localhost and 127.0.0.1 over HTTP and HTTPS
# since they are all distinct CORS origins.
# If you access the app via another hostname or IP (e.g., http://192.168.1.100), add that origin here as well.
# For production: https://yourdomain.com,https://www.yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,https://localhost,https://127.0.0.1

# WebSocket Testing Configuration
# Set to true to test WebSocket disconnection scenarios (header shows "WebSocket Disconnected")
# WARNING: This must NEVER be enabled (true) in production deployments
# Only use for local/testing purposes to verify client handling of WebSocket failures
# Default: false
REJECT_SOCKETIO_CONNECTIONS=false