# =============================================================================
# Database Configuration
# =============================================================================
# Root password for the MySQL container. Not used by the app directly, but
# required by the MySQL Docker image on first run to initialise the database.
# Use a strong, unique password in production.
MYSQL_ROOT_PASSWORD=your_root_password_here

# Name of the database the application will use.
MYSQL_DATABASE=aft_db

# Credentials the application uses to connect to the database.
# Grant only the minimum required privileges to this user.
MYSQL_USER=aft_user
MYSQL_PASSWORD=your_user_password_here

# =============================================================================
# Application Environment
# =============================================================================
# Controls Flask's runtime behaviour.
#
# FLASK_ENV
#   production  — Recommended for live deployments. Disables the interactive
#                 debugger and detailed error pages so internals are never
#                 exposed to end users.
#   development — Enables extra logging and developer-friendly error pages.
#                 Never use in production.
FLASK_ENV=production

# FLASK_DEBUG
#   0 — Debug mode off. Required for production. Keeps error details private
#       and disables the auto-reloader.
#   1 — Debug mode on. Enables the interactive debugger (exposes source code
#       and stack traces to anyone who sees an error page) and auto-reloads
#       the server on code changes. Development only.
FLASK_DEBUG=0

# =============================================================================
# Flask Secret Key (REQUIRED)
# =============================================================================
# Used to cryptographically sign session cookies and CSRF tokens.
# Must be a strong, random value — never a guessable string.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# WARNING: The server will refuse to start if this is not set.
# Never reuse this value across environments. Rotate immediately if compromised.
SECRET_KEY=replace-with-a-generated-random-secret

# =============================================================================
# Redis Configuration
# =============================================================================
# Connection URL for the Redis instance used for server-side session storage.
# The default points to the Redis service defined in compose.yml.
# Update the hostname/port if Redis is hosted separately.
REDIS_URL=redis://redis:6379/0

# =============================================================================
# Session Storage
# =============================================================================
# ENABLE_SERVER_SIDE_SESSIONS
#   true  — Sessions are stored in Redis (recommended for production). Requires
#           REDIS_URL to be set. Prevents session data from being read or
#           tampered with by clients.
#   false — Sessions are stored as signed cookies on the client. Simpler to
#           run (no Redis needed) but session contents are visible to the client
#           and cookie size limits apply.
ENABLE_SERVER_SIDE_SESSIONS=true

# =============================================================================
# Session Cookie Security
# =============================================================================
# SESSION_COOKIE_SECURE
#   true  — The browser will only send the session cookie over HTTPS (required
#           for production to prevent session hijacking over plain HTTP).
#   false — Cookie is also sent over plain HTTP. Only set this for controlled
#           local development when running without HTTPS.
SESSION_COOKIE_SECURE=true

# =============================================================================
# Health Check Security
# =============================================================================
# Secret token required by the internal readiness health check endpoint.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
HEALTHCHECK_TOKEN=replace-with-a-generated-random-healthcheck-token

# IP address permitted to call the internal readiness endpoint.
# The default (127.0.0.1) works for same-host Docker Compose deployments.
# Change this if your health checker runs on a different host.
HEALTHCHECK_ALLOWED_SOURCE_IP=127.0.0.1

# =============================================================================
# CORS Configuration
# =============================================================================
# Comma-separated list of origins allowed to make cross-origin requests
# (HTTP, HTTPS, and WebSocket). Only exact origins are matched — no wildcards.
#
# Production: list only your real domain(s).
#   Example: https://yourdomain.com,https://www.yourdomain.com
#
# Development: add every origin you access the app from. localhost and
#   127.0.0.1 are distinct CORS origins so both must be listed if used.
#   HTTP and HTTPS variants are also distinct.
#   Example: http://localhost,http://127.0.0.1,https://localhost,https://127.0.0.1
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# =============================================================================
# WebSocket Testing (Development / QA Only)
# =============================================================================
# REJECT_SOCKETIO_CONNECTIONS
#   true  — The server actively rejects all WebSocket connections. Useful for
#           testing that the frontend handles disconnection gracefully.
#           WARNING: NEVER set to true in production — it will break real-time
#           features for all users.
#   false — Normal operation. WebSocket connections are accepted (default).
REJECT_SOCKETIO_CONNECTIONS=false